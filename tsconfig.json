{
	"compilerOptions": {
		"experimentalDecorators": true,
		"skipLibCheck": true,
		"importHelpers": true,
		"sourceMap": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		// The next 4 lines are for turning down typescript checking, we really should have
		// separate tsconfigs for the tests and src files with different nag levels.
		// See: https://phabricator.wikimedia.org/T422611
		"ignoreDeprecations": "6.0",
		"alwaysStrict": false,
		"strictNullChecks": false,
		"noImplicitAny": false,
		"types": [
			"webpack-env",
		],
		"paths": {
			"@src/*": [ "./src/*" ],
			"@test/*": [ "./tests/*" ]
		},
		"lib": [
			"esnext",
			"dom",
			"dom.iterable",
			"scripthost",
			"es5",
			"es2015.promise"
		]
	},
	"exclude": [
		"node_modules"
	]
}
